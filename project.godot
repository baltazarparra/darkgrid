; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="caipora"
config/description="Roguelike brasileiro de horror folclórico"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"
run/main_scene="res://scenes/ui/main_menu.tscn"
boot_splash/image="res://assets/sprites/boot_splash.png"
boot_splash/bg_color=Color(0.016, 0.024, 0.016, 1)
boot_splash/use_filter=false
boot_splash/fullsize=false

[autoload]

GameState="*res://scripts/core/game_state.gd"
SignalBus="*res://scripts/core/signal_bus.gd"
MetaProgression="*res://scripts/core/meta_progression.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[gui]

theme/custom="res://assets/fonts/theme.tres"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
